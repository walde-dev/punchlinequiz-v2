# ─────────────────────────────────────────────────────────────
# punchlinequiz-v2 — environment variables (source of truth)
# Copy to .env (root) and/or apps/web/.env and fill in values.
# All variables are server-side only. No client/VITE_ vars yet.
# ─────────────────────────────────────────────────────────────

# Neon Postgres connection string. Required.
# Used by: apps/web (runtime), packages/db (migrations, seed, backfill).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Bearer token for the admin API (POST/PATCH/DELETE /api/admin/*).
# Required in any environment that should accept admin writes
# (hermes CLI, pquiz-* skills, etc.). Generate with: openssl rand -base64 32
PQUIZ_ADMIN_TOKEN=replace-with-long-random-string

# Axiom log ingest. Optional — if unset, server-side events are no-ops.
# Token: create an API token with ingest permission for the dataset below.
AXIOM_TOKEN=
AXIOM_DATASET=punchlinequiz

# Only used by local skill tooling (impeccable). Not needed in Vercel.
# IMPECCABLE_CONTEXT_DIR=
